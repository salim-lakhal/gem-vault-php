{% extends 'base.html.twig' %}

{% block title %}Gemstones - Gem Vault{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-grid me-2"></i>Gemstones</h1>
        {% if app.user %}
            <a href="{{ path('app_gemstone_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add New Gemstone
            </a>
        {% endif %}
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="GET" action="{{ path('app_gemstone_index') }}">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label for="q" class="form-label">Search</label>
                        <input type="text" class="form-control" id="q" name="q" value="{{ app.request.query.get('q') }}" placeholder="Search gemstones...">
                    </div>
                    <div class="col-md-2">
                        <label for="type" class="form-label">Type</label>
                        <select class="form-select" id="type" name="type">
                            <option value="">All Types</option>
                            {% for t in types %}
                                <option value="{{ t }}" {{ app.request.query.get('type') == t ? 'selected' }}>{{ t }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="color" class="form-label">Color</label>
                        <select class="form-select" id="color" name="color">
                            <option value="">All Colors</option>
                            {% for c in colors %}
                                <option value="{{ c }}" {{ app.request.query.get('color') == c ? 'selected' }}>{{ c }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="rarity" class="form-label">Rarity</label>
                        <select class="form-select" id="rarity" name="rarity">
                            <option value="">All Rarities</option>
                            {% for r in rarities %}
                                <option value="{{ r }}" {{ app.request.query.get('rarity') == r ? 'selected' }}>{{ r }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-outline-primary me-2">
                            <i class="bi bi-search me-1"></i>Filter
                        </button>
                        <a href="{{ path('app_gemstone_index') }}" class="btn btn-outline-secondary">Clear</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {% if gemstones|length > 0 %}
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for gemstone in gemstones %}
                <div class="col">
                    <div class="card h-100">
                        {% if gemstone.imageName %}
                            <img src="{{ vich_uploader_asset(gemstone, 'imageFile') }}" class="card-img-top" alt="{{ gemstone.name }}" style="height: 220px; object-fit: cover;">
                        {% else %}
                            <div class="gem-placeholder card-img-top">
                                <i class="bi bi-gem"></i>
                            </div>
                        {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ gemstone.name }}</h5>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-info text-dark">{{ gemstone.type }}</span>
                                <span class="badge badge-rarity bg-warning text-dark">{{ gemstone.rarity }}</span>
                            </div>
                            <p class="card-text text-muted mb-1">
                                <i class="bi bi-feather me-1"></i>{{ gemstone.weight }} ct
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <a href="{{ path('app_gemstone_show', {id: gemstone.id}) }}" class="btn btn-sm btn-outline-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if totalPages is defined and totalPages > 1 %}
            <nav class="mt-4" aria-label="Gemstone pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item {{ page <= 1 ? 'disabled' }}">
                        <a class="page-link" href="{{ path('app_gemstone_index', app.request.query.all|merge({page: page - 1})) }}">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>
                    {% for i in 1..totalPages %}
                        <li class="page-item {{ page == i ? 'active' }}">
                            <a class="page-link" href="{{ path('app_gemstone_index', app.request.query.all|merge({page: i})) }}">{{ i }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {{ page >= totalPages ? 'disabled' }}">
                        <a class="page-link" href="{{ path('app_gemstone_index', app.request.query.all|merge({page: page + 1})) }}">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-gem display-1 text-muted"></i>
            <p class="text-muted mt-3">No gemstones found.</p>
        </div>
    {% endif %}
{% endblock %}
