<form method="post" action="{{ path('app_gemstone_delete', {id: gemstone.id}) }}" onsubmit="return confirm('Are you sure you want to delete this gemstone?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ gemstone.id) }}">
    <button type="submit" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i>Delete
    </button>
</form>
