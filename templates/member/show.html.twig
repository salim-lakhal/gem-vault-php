{% extends 'base.html.twig' %}

{% block title %}{{ member.username|default(member.email) }} - Gem Vault{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_member_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to members
        </a>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-person-fill text-primary" style="font-size: 2.5rem;"></i>
                    </div>
                    <h4>{{ member.username|default('No username') }}</h4>
                    <p class="text-muted mb-0">
                        <i class="bi bi-envelope me-1"></i>{{ member.email }}
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">
                    <i class="bi bi-images me-2"></i>Galleries
                    <span class="badge bg-secondary">{{ member.galleries|length }}</span>
                </h4>
                {% if app.user and app.user.id == member.id %}
                    <a href="{{ path('app_gallery_new') }}" class="btn btn-sm btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>New Gallery
                    </a>
                {% endif %}
            </div>

            {% if member.galleries|length > 0 %}
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    {% for gallery in member.galleries %}
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="card-title mb-1">{{ gallery.name }}</h6>
                                        {% if gallery.isPublic %}
                                            <span class="badge bg-success">Public</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Private</span>
                                        {% endif %}
                                    </div>
                                    {% if gallery.description %}
                                        <p class="card-text text-muted small">{{ gallery.description|length > 80 ? gallery.description|slice(0, 80) ~ '...' : gallery.description }}</p>
                                    {% endif %}
                                    <span class="badge bg-light text-dark">
                                        <i class="bi bi-gem me-1"></i>{{ gallery.gemstones|length }} gemstone{{ gallery.gemstones|length != 1 ? 's' }}
                                    </span>
                                </div>
                                <div class="card-footer bg-transparent border-0 pb-3">
                                    <a href="{{ path('app_gallery_show', {id: gallery.id}) }}" class="btn btn-sm btn-outline-primary w-100">View</a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-4">
                    <p class="text-muted">No galleries yet.</p>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
