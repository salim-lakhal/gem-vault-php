{% extends 'base.html.twig' %}

{% block title %}New Gallery - Gem Vault{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_gallery_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to galleries
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-white">
                    <h3 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Gallery</h3>
                </div>
                <div class="card-body">
                    {{ include('gallery/_form.html.twig', {button_label: 'Create'}) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
