{% extends 'base.html.twig' %}

{% block title %}Galleries - Gem Vault{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-images me-2"></i>Galleries</h1>
        {% if app.user %}
            <a href="{{ path('app_gallery_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Create New Gallery
            </a>
        {% endif %}
    </div>

    {% if galleries|length > 0 %}
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for gallery in galleries %}
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">{{ gallery.name }}</h5>
                                {% if gallery.isPublic %}
                                    <span class="badge bg-success">Public</span>
                                {% else %}
                                    <span class="badge bg-secondary">Private</span>
                                {% endif %}
                            </div>
                            {% if gallery.description %}
                                <p class="card-text text-muted">{{ gallery.description|length > 120 ? gallery.description|slice(0, 120) ~ '...' : gallery.description }}</p>
                            {% endif %}
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="badge bg-secondary">
                                    <i class="bi bi-gem me-1"></i>{{ gallery.gemstones|length }} gemstone{{ gallery.gemstones|length != 1 ? 's' }}
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-person me-1"></i>{{ gallery.creator.username|default(gallery.creator.email|default('Unknown')) }}
                                </small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <a href="{{ path('app_gallery_show', {id: gallery.id}) }}" class="btn btn-sm btn-outline-primary w-100">
                                View Gallery
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-images display-1 text-muted"></i>
            <p class="text-muted mt-3">No galleries found.</p>
        </div>
    {% endif %}
{% endblock %}
