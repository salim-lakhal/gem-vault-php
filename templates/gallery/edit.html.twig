{% extends 'base.html.twig' %}

{% block title %}Edit {{ gallery.name }} - Gem Vault{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_gallery_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to galleries
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h3 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Gallery</h3>
                </div>
                <div class="card-body">
                    {{ include('gallery/_form.html.twig', {button_label: 'Update'}) }}
                </div>
            </div>

            <div class="card border-danger">
                <div class="card-header bg-danger bg-opacity-10 text-danger">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h5>
                </div>
                <div class="card-body">
                    <p class="mb-3">This action cannot be undone. This will permanently delete this gallery.</p>
                    {{ include('gallery/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
