{% extends 'base.html.twig' %}

{% block title %}{{ gallery.name }} - Gem Vault{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_gallery_index') }}" class="text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to galleries
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="mb-2">{{ gallery.name }}</h1>
                    {% if gallery.description %}
                        <p class="lead text-muted">{{ gallery.description }}</p>
                    {% endif %}
                </div>
                <div>
                    {% if gallery.isPublic %}
                        <span class="badge bg-success fs-6">Public</span>
                    {% else %}
                        <span class="badge bg-secondary fs-6">Private</span>
                    {% endif %}
                </div>
            </div>
            <div class="mt-3">
                <small class="text-muted">
                    <i class="bi bi-person me-1"></i>Created by {{ gallery.creator.username|default(gallery.creator.email|default('Unknown')) }}
                </small>
            </div>

            {% if app.user %}
                <div class="mt-3 d-flex gap-2">
                    <a href="{{ path('app_gallery_edit', {id: gallery.id}) }}" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    {{ include('gallery/_delete_form.html.twig') }}
                </div>
            {% endif %}
        </div>
    </div>

    <h4 class="mb-3">
        <i class="bi bi-gem me-2"></i>Gemstones
        <span class="badge bg-secondary">{{ gallery.gemstones|length }}</span>
    </h4>

    {% if gallery.gemstones|length > 0 %}
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3">
            {% for gemstone in gallery.gemstones %}
                <div class="col">
                    <div class="card h-100">
                        {% if gemstone.imageName %}
                            <img src="{{ vich_uploader_asset(gemstone, 'imageFile') }}" class="card-img-top" alt="{{ gemstone.name }}" style="height: 160px; object-fit: cover;">
                        {% else %}
                            <div class="gem-placeholder card-img-top" style="min-height: 120px; font-size: 1.5rem;">
                                <i class="bi bi-gem"></i>
                            </div>
                        {% endif %}
                        <div class="card-body p-2 text-center">
                            <h6 class="card-title mb-1">{{ gemstone.name }}</h6>
                            <span class="badge bg-info text-dark">{{ gemstone.type }}</span>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-2">
                            <a href="{{ path('app_gemstone_show', {id: gemstone.id}) }}" class="btn btn-sm btn-outline-primary w-100">View</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-gem display-4 text-muted"></i>
            <p class="text-muted mt-3">No gemstones in this gallery yet.</p>
        </div>
    {% endif %}
{% endblock %}
