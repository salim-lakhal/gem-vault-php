{% extends 'base.html.twig' %}

{% block title %}Collections - Gem Vault{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-collection me-2"></i>Collections</h1>
    </div>

    {% if collections|length > 0 %}
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for collection in collections %}
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ collection.name }}</h5>
                            {% if collection.description %}
                                <p class="card-text text-muted">{{ collection.description|length > 120 ? collection.description|slice(0, 120) ~ '...' : collection.description }}</p>
                            {% endif %}
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="badge bg-secondary">
                                    <i class="bi bi-gem me-1"></i>{{ collection.gemstones|length }} gemstone{{ collection.gemstones|length != 1 ? 's' }}
                                </span>
                                <small class="text-muted">
                                    <i class="bi bi-person me-1"></i>{{ collection.owner.email|default('Unknown') }}
                                </small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pb-3">
                            <a href="{{ path('app_collection_show', {id: collection.id}) }}" class="btn btn-sm btn-outline-primary w-100">
                                View Collection
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-collection display-1 text-muted"></i>
            <p class="text-muted mt-3">No collections found.</p>
        </div>
    {% endif %}
{% endblock %}
