# Application environment (dev, test, prod)
APP_ENV=dev

# Symfony secret — generate a unique value for production
APP_SECRET=change_me_in_production

# Database connection string — update credentials and host for your setup
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/gem_vault?serverVersion=16&charset=utf8"

# Messenger transport DSN
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
